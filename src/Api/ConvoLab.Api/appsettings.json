{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=convolab.db"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/convolab-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "ConvoLab"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "your-secret-key-change-in-production",
    "ExpirationMinutes": 60
  },
  "Gemini": {
    "Model": "gemini-2.5-flash",
    "MaxContextTokens": 1000000,
    "MaxOutputTokens": 8192,
    "TypicalLatencyMs": 900
  },
  "Intelligence": {
    "MonthlyBudgetZar": 500
  },
  "Evaluation": {
    "MinimumGroundedness": 0.8,
    "MinimumRelevance": 0.8,
    "MinimumSafety": 0.95,
    "MinimumOverallScore": 0.82,
    "FailureAction": "Review"
  }
}
