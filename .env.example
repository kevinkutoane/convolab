# Copy to .env for local Docker development. Never commit real secrets.
CONVOLAB_BOOTSTRAP_ADMIN_EMAIL=kev@test.com
CONVOLAB_BOOTSTRAP_ADMIN_PASSWORD=test123
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CONVOLAB_MONTHLY_AI_BUDGET_ZAR=500
