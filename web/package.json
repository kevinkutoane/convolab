{
  "name": "convolab-studio",
  "private": true,
  "version": "1.0.0-alpha.12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/check-bundle-budget.mjs",
    "build:app": "tsc -b && vite build",
    "test:bundle": "node scripts/check-bundle-budget.mjs",
    "test:baseline": "node scripts/verify-baseline.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node scripts/run-tests.mjs && node scripts/audit-interactions.mjs",
    "test:interactions": "node scripts/audit-interactions.mjs",
    "test:browser": "playwright test",
    "test:browser:report": "playwright show-report",
    "test:cross-capability": "node scripts/cross-capability-smoke.mjs",
    "test:restart": "node scripts/verify-restart.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  },
  "description": "The engineering workspace for ConvoLab Platform Core."
}
